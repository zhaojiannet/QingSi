# 安全密钥配置
# 生产环境必须设置新的密钥！
# 生成新密钥命令: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-here
SESSION_SECRET=your-session-secret-here

# 环境配置
NODE_ENV=production

# 日志级别（可选，默认 info）
LOG_LEVEL=info

# CORS配置 - 多个域名用逗号分隔
# 生产环境请设置您的实际域名
CORS_ORIGIN=https://yourdomain.com

# Cookie安全设置
# 生产环境必须设置为true (需要HTTPS)
SECURE_COOKIE=true

# Cookie 域（可选，跨子域共享 session 时设置，如 .yourdomain.com）
COOKIE_DOMAIN=

# 反向代理跳数（可选）：部署在 nginx 等反代后设为代理层数（通常 1），
# 直连暴露端口时留空（按真实连接 IP 限流，避免伪造 X-Forwarded-For 绕过）
TRUST_PROXY=

# 管理员账户配置
# 首次部署时设置管理员账户
ADMIN_USERNAME=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-password-here

# 数据库配置
DATABASE_URL=mysql://user:password@localhost:3306/database
DB_CONNECTION_LIMIT=10

# 微信公众号推送
# 使用 Cloudflare Workers 部署 wxpush
# 部署教程：https://github.com/frankiejun/wxpush
WXPUSH_URL=https://your-worker.workers.dev/wxsend
WXPUSH_TOKEN=your-api-token