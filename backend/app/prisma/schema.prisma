generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Member {
  id               String        @id
  phone            String
  name             String
  gender           Gender?       @default(UNKNOWN)
  birthday         DateTime?
  registrationDate DateTime      @default(now())
  status           MemberStatus  @default(ACTIVE)
  notes            String?       @db.Text
  appointments     Appointment[]
  cards            Card[]
  transactions     Transaction[]
  pendingPayments  PendingPayment[]

  @@index([name])
  @@index([phone])
  @@index([status])
  @@index([registrationDate])
  @@index([birthday])
}

model Card {
  id                  String        @id
  memberId            String
  cardTypeId          String
  balance             Decimal       @default(0.00) @db.Decimal(10, 2)
  issueDate           DateTime      @default(now())
  expiryDate          DateTime?
  status              CardStatus    @default(ACTIVE)
  // 自定义面值卡相关字段
  isCustomCard        Boolean       @default(false)
  customAmount        Decimal?      @db.Decimal(10, 2)
  discountSource      String        @default("card_type") // "card_type" or "custom"
  customDiscountRate  Decimal?      @db.Decimal(4, 3)
  cardType            CardType      @relation(fields: [cardTypeId], references: [id])
  member              Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactions        Transaction[]

  @@index([memberId])
  @@index([cardTypeId])
  @@index([status])
  @@index([issueDate])
  @@index([memberId, status])
  @@index([balance])
  @@index([isCustomCard])
}

model CardType {
  id           String        @id
  name         String        @unique
  initialPrice Decimal       @db.Decimal(10, 2)
  discountRate Decimal       @db.Decimal(4, 3)
  status       ServiceStatus @default(AVAILABLE)
  cards        Card[]

  @@index([status])
}

model Service {
  id              String            @id
  name            String            @unique
  standardPrice   Decimal           @db.Decimal(10, 2)
  status          ServiceStatus     @default(AVAILABLE)
  sortOrder       Int               @default(99)
  noDiscount      Boolean           @default(false)
  TransactionItem TransactionItem[]
  appointments    Appointment[]     @relation("AppointmentToService")

  @@index([status])
  @@index([sortOrder])
  @@index([noDiscount])
}

model Transaction {
  id               String            @id
  memberId         String?
  staffId          String?
  customerName     String?           // 非会员顾客姓名（手动输入）
  summary          String?
  totalAmount      Decimal           @db.Decimal(10, 2)
  actualPaidAmount Decimal           @db.Decimal(10, 2)
  discountAmount   Decimal           @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  cardId           String?
  transactionTime  DateTime          @default(now())
  notes            String?
  appointment      Appointment?
  cardUsed         Card?             @relation(fields: [cardId], references: [id])
  member           Member?           @relation(fields: [memberId], references: [id])
  staff            Staff?            @relation(fields: [staffId], references: [id])
  items            TransactionItem[]

  @@index([transactionTime])
  @@index([memberId])
  @@index([staffId])
  @@index([paymentMethod])
  @@index([cardId])
  @@index([transactionTime, memberId])
  @@index([transactionTime, paymentMethod])
}

model TransactionItem {
  id            String      @id
  transactionId String
  serviceId     String
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int         @default(1)
  service       Service     @relation(fields: [serviceId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([serviceId])
}

model Staff {
  id               String        @id
  name             String
  position         String
  phone            String?       @unique
  hireDate         DateTime      @default(now())
  status           StaffStatus   @default(ACTIVE)
  countsCommission Boolean       @default(true)
  sortOrder        Int           @default(99)
  appointments     Appointment[]
  transactions     Transaction[]
  user             User?

  @@index([status])
  @@index([hireDate])
  @@index([countsCommission])
  @@index([sortOrder])
}

model Appointment {
  id              String            @id
  memberId        String?
  customerName    String
  customerPhone   String
  appointmentTime DateTime
  assignedStaffId String?
  status          AppointmentStatus @default(PENDING)
  notes           String?
  transactionId   String?           @unique
  staff           Staff?            @relation(fields: [assignedStaffId], references: [id])
  member          Member?           @relation(fields: [memberId], references: [id])
  transaction     Transaction?      @relation(fields: [transactionId], references: [id])
  services        Service[]         @relation("AppointmentToService")

  @@index([appointmentTime])
  @@index([status])
  @@index([memberId])
  @@index([assignedStaffId])
  @@index([customerPhone])
  @@index([appointmentTime, status])
  @@index([appointmentTime, assignedStaffId])
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  role          Role           @default(STYLIST)
  createdAt     DateTime       @default(now())
  staffId       String?        @unique
  refreshTokens RefreshToken[]
  staff         Staff?         @relation(fields: [staffId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemConfig {
  id                 Int     @id @default(1)
  enableLoginCaptcha Boolean @default(true)
}

model PendingPayment {
  id          String   @id
  memberId    String
  amount      Decimal  @db.Decimal(10, 2)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([createdAt])
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum CardStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  FROZEN
}

enum ServiceStatus {
  AVAILABLE
  UNAVAILABLE
}

enum PaymentMethod {
  CASH
  WECHAT_PAY
  ALIPAY
  DOUYIN
  MEITUAN
  CARD_SWIPE
  MEMBER_CARD
  OTHER
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Role {
  ADMIN
  MANAGER
  STYLIST
  ASSISTANT
}
