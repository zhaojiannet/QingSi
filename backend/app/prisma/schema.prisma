generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Member {
  id               String        @id
  phone            String
  name             String
  gender           Gender?       @default(UNKNOWN)
  birthday         DateTime?
  registrationDate DateTime      @default(now())
  status           MemberStatus  @default(ACTIVE)
  notes            String?       @db.Text
  appointments     Appointment[]
  cards            Card[]
  transactions     Transaction[]

  @@index([name])
  @@index([phone])
  @@index([status])
  @@index([registrationDate])
  @@index([birthday])
}

model Card {
  id                 String        @id
  memberId           String
  cardTypeId         String
  balance            Decimal       @default(0.00) @db.Decimal(10, 2)
  issueDate          DateTime      @default(now())
  expiryDate         DateTime?
  status             CardStatus    @default(ACTIVE)
  customAmount       Decimal?      @db.Decimal(10, 2)
  customDiscountRate Decimal?      @db.Decimal(4, 3)
  discountSource     String        @default("card_type")
  isCustomCard       Boolean       @default(false)
  cardType           CardType      @relation(fields: [cardTypeId], references: [id])
  member             Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  transactionLinks   TransactionCardLink[]

  @@index([cardTypeId])
  @@index([status])
  @@index([issueDate])
  @@index([memberId, status])
}

model CardType {
  id           String        @id
  name         String        @unique
  initialPrice Decimal       @db.Decimal(10, 2)
  discountRate Decimal       @db.Decimal(4, 3)
  status       ServiceStatus @default(AVAILABLE)
  cards        Card[]

  @@index([status])
}

model Service {
  id              String            @id
  name            String            @unique
  standardPrice   Decimal           @db.Decimal(10, 2)
  status          ServiceStatus     @default(AVAILABLE)
  sortOrder       Int               @default(99)
  noDiscount      Boolean           @default(false)
  TransactionItem TransactionItem[]
  appointments    Appointment[]     @relation("AppointmentToService")

  @@index([status])
  @@index([sortOrder])
  @@index([noDiscount])
}

model Transaction {
  id               String            @id
  memberId         String?
  staffId          String?
  summary          String?
  totalAmount      Decimal           @db.Decimal(10, 2)
  actualPaidAmount Decimal           @db.Decimal(10, 2)
  discountAmount   Decimal           @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  cardId           String?
  transactionTime  DateTime          @default(now())
  notes            String?
  customerName     String?
  isPending        Boolean           @default(false)
  transactionType  TransactionType   @default(NORMAL)
  balanceSnapshot  Json?             // 记录交易前后的卡余额快照，格式: { totalBalanceBefore, totalBalanceAfter, cards: [{ cardId, cardName, balanceBefore, balanceAfter, isUsed }] }
  appointment      Appointment?
  cardUsed         Card?             @relation(fields: [cardId], references: [id])
  member           Member?           @relation(fields: [memberId], references: [id])
  staff            Staff?            @relation(fields: [staffId], references: [id])
  items            TransactionItem[]
  cardLinks        TransactionCardLink[]

  @@index([transactionTime])
  @@index([memberId])
  @@index([staffId])
  @@index([paymentMethod])
  @@index([cardId])
  @@index([transactionTime, memberId])
  @@index([transactionTime, paymentMethod])
  @@index([transactionType])
  @@index([isPending])
  @@index([memberId, isPending])
}

model TransactionCardLink {
  id            String      @id @default(cuid())
  transactionId String
  cardId        String
  cardName      String
  amount        Decimal     @db.Decimal(10, 2)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  card          Card        @relation(fields: [cardId], references: [id])

  @@index([transactionId])
  @@index([cardId])
}

model TransactionItem {
  id            String      @id
  transactionId String
  serviceId     String
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int         @default(1)
  service       Service     @relation(fields: [serviceId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([serviceId])
}

model Staff {
  id               String        @id
  name             String
  position         String
  phone            String?       @unique
  hireDate         DateTime      @default(now())
  status           StaffStatus   @default(ACTIVE)
  countsCommission Boolean       @default(true)
  sortOrder        Int           @default(99)
  appointments     Appointment[]
  transactions     Transaction[]
  user             User?

  @@index([status])
  @@index([hireDate])
  @@index([countsCommission])
  @@index([sortOrder])
}

model Appointment {
  id              String            @id
  memberId        String?
  customerName    String
  customerPhone   String
  appointmentTime DateTime
  assignedStaffId String?
  status          AppointmentStatus @default(PENDING)
  notes           String?
  transactionId   String?           @unique
  staff           Staff?            @relation(fields: [assignedStaffId], references: [id])
  member          Member?           @relation(fields: [memberId], references: [id])
  transaction     Transaction?      @relation(fields: [transactionId], references: [id])
  services        Service[]         @relation("AppointmentToService")

  @@index([appointmentTime])
  @@index([status])
  @@index([memberId])
  @@index([assignedStaffId])
  @@index([customerPhone])
  @@index([appointmentTime, status])
  @@index([appointmentTime, assignedStaffId])
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  role          Role           @default(STYLIST)
  createdAt     DateTime       @default(now())
  staffId       String?        @unique
  refreshTokens RefreshToken[]
  staff         Staff?         @relation(fields: [staffId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemConfig {
  id                    Int       @id @default(1)
  enableLoginCaptcha    Boolean   @default(true)
  enableTransactionVoid Boolean   @default(false)
  voidEnabledAt         DateTime?
  bookingCode           String?   @db.VarChar(32)
  bookingCodeUpdatedAt  DateTime?
}

model VoidLog {
  id               String   @id @default(cuid())
  originalTxId     String
  originalTxTime   DateTime
  memberId         String?
  memberName       String?
  summary          String?
  totalAmount      Decimal  @db.Decimal(10, 2)
  actualPaidAmount Decimal  @db.Decimal(10, 2)
  paymentMethod    String
  cardInfo         String?  @db.Text
  balanceRestored  String?  @db.Text
  balanceSnapshot  Json?    // 原始交易的余额快照，格式与 Transaction.balanceSnapshot 一致
  voidedAt         DateTime @default(now())
  voidedBy         String
  voidedByName     String
  reason           String?

  @@index([voidedAt])
  @@index([memberId])
  @@index([voidedBy])
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum CardStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  FROZEN
}

enum ServiceStatus {
  AVAILABLE
  UNAVAILABLE
}

enum PaymentMethod {
  CASH
  WECHAT_PAY
  ALIPAY
  DOUYIN
  MEITUAN
  CARD_SWIPE
  MEMBER_CARD
  OTHER
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TransactionType {
  NORMAL
  PENDING
  PENDING_CLEAR
}

enum Role {
  ADMIN
  MANAGER
  STYLIST
  ASSISTANT
}
