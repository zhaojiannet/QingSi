// backend/app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. 会员管理模块
model Member {
  id                String       @id
  phone             String       @unique
  name              String
  gender            Gender?      @default(UNKNOWN)
  birthday          DateTime?
  registrationDate  DateTime     @default(now())
  lastVisitDate     DateTime?
  status            MemberStatus @default(ACTIVE)
  notes             String?      @db.Text
  
  cards             Card[]
  transactions      Transaction[]
  appointments      Appointment[]

  @@index([name])
  @@index([phone])
  @@index([status])
  @@index([registrationDate])
  @@index([birthday])
}

enum MemberStatus {
  ACTIVE    // 对应业务术语: 正常
  INACTIVE  // 对应业务术语: 冻结
  DELETED   // 对应业务术语: 注销账户
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

// 2. 会员卡管理模块
model Card {
  id            String     @id
  memberId      String
  cardTypeId    String
  balance       Decimal    @default(0.0) @db.Decimal(10, 2)
  issueDate     DateTime   @default(now())
  expiryDate    DateTime?
  status        CardStatus @default(ACTIVE)
  
  member        Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  cardType      CardType   @relation(fields: [cardTypeId], references: [id])
  transactions  Transaction[]

  @@index([memberId])
  @@index([cardTypeId])
  @@index([status])
  @@index([issueDate])
  @@index([memberId, status])
  @@index([balance])
}

enum CardStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  FROZEN
}

model CardType {
  id            String   @id
  name          String   @unique
  initialPrice  Decimal  @db.Decimal(10, 2)
  discountRate  Decimal  @db.Decimal(4, 3) 
  status        ServiceStatus @default(AVAILABLE)
  
  cards         Card[]

  @@index([status])
}

// 3. 项目/服务管理模块
model Service {
  id              String         @id
  name            String         @unique
  standardPrice   Decimal        @db.Decimal(10, 2)
  status          ServiceStatus  @default(AVAILABLE)
  sortOrder       Int            @default(99)

  TransactionItem TransactionItem[]
  // --- 核心修复点: 为关联字段添加名称 'appointments' ---
  appointments    Appointment[]

  @@index([status])
  @@index([sortOrder])
}

enum ServiceStatus {
  AVAILABLE
  UNAVAILABLE
}

// 4. 消费/收银模块
model Transaction {
  id                String          @id
  memberId          String?
  staffId           String?
  // --- 核心修改：新增 summary 字段 ---
  summary           String?         // 用于记录交易摘要，如“办理【xxx卡】”或“项目消费”
  totalAmount       Decimal         @db.Decimal(10, 2)
  actualPaidAmount  Decimal         @db.Decimal(10, 2)
  discountAmount    Decimal         @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  cardId            String?
  transactionTime   DateTime        @default(now())
  notes             String?
  
  member            Member?         @relation(fields: [memberId], references: [id], onDelete: SetNull)
  staff             Staff?          @relation(fields: [staffId], references: [id], onDelete: SetNull)
  cardUsed          Card?           @relation(fields: [cardId], references: [id], onDelete: SetNull)
  items             TransactionItem[]
  appointment       Appointment?
  
  @@index([transactionTime])
  @@index([memberId])
  @@index([staffId])
  @@index([paymentMethod])
  @@index([cardId])
  @@index([transactionTime, memberId])
  @@index([transactionTime, paymentMethod])
}


enum PaymentMethod {
  CASH
  WECHAT_PAY
  ALIPAY
  CARD_SWIPE
  MEMBER_CARD
  OTHER
}

model TransactionItem {
  id            String      @id
  transactionId String
  serviceId     String
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int         @default(1)

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@index([transactionId])
  @@index([serviceId])
}


// 5. 员工管理模块
model Staff {
  id               String        @id
  name             String
  position         String
  phone            String?       @unique
  hireDate         DateTime      @default(now())
  status           StaffStatus   @default(ACTIVE)
  countsCommission Boolean       @default(true)
  sortOrder        Int           @default(99)
  
  user             User?
  transactions     Transaction[]
  appointments     Appointment[]

  @@index([status])
  @@index([hireDate])
  @@index([countsCommission])
  @@index([sortOrder])
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

// 6. 预约管理模块
model Appointment {
  id              String            @id
  memberId        String?
  customerName    String
  customerPhone   String
  appointmentTime DateTime
  assignedStaffId String?
  status          AppointmentStatus @default(PENDING)
  notes           String?
  
  member          Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  staff           Staff?            @relation(fields: [assignedStaffId], references: [id], onDelete: SetNull)
  services        Service[]
  transactionId   String?           @unique
  transaction     Transaction?      @relation(fields: [transactionId], references: [id])

  @@index([appointmentTime])
  @@index([status])
  @@index([memberId])
  @@index([assignedStaffId])
  @@index([customerPhone])
  @@index([appointmentTime, status])
  @@index([appointmentTime, assignedStaffId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      Role     @default(STYLIST)
  createdAt DateTime @default(now())
  
  staffId   String?  @unique
  staff     Staff?   @relation(fields: [staffId], references: [id])

  refreshTokens RefreshToken[]
}

enum Role {
  ADMIN
  MANAGER
  STYLIST
  ASSISTANT
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemConfig {
  id                  Int     @id @default(1)
  enableLoginCaptcha  Boolean @default(true)
}